{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["metricmesh"],
  "templating": {
    "list": [
      {
        "name": "metric",
        "label": "Metric",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "metricmesh-tsdb" },
        "query": "SELECT DISTINCT metric_name FROM metrics ORDER BY 1",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1,
        "current": {}
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "title": "MetricMesh — Overview",
  "uid": "metricmesh-overview",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total alerts",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "metricmesh-tsdb" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "metricmesh-tsdb" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT count(*) AS \"Total alerts\" FROM alerts WHERE $__timeFilter(created_at)"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active metrics",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "metricmesh-tsdb" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "metricmesh-tsdb" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT count(DISTINCT metric_name) AS \"Active metrics\" FROM metrics WHERE $__timeFilter(\"time\")"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Datapoints ingested",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "metricmesh-tsdb" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "metricmesh-tsdb" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT count(*) AS \"Datapoints\" FROM metrics WHERE $__timeFilter(\"time\")"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Detectors firing",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "postgres", "uid": "metricmesh-tsdb" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "metricmesh-tsdb" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT count(DISTINCT detector) AS \"Detectors\" FROM alerts WHERE $__timeFilter(created_at)"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Ingest rate (datapoints / min)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "metricmesh-tsdb" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 40, "lineWidth": 1 }, "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "metricmesh-tsdb" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroupAlias(\"time\", '1m'), count(*) AS \"datapoints\" FROM metrics WHERE $__timeFilter(\"time\") GROUP BY 1 ORDER BY 1"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Anomaly alerts by detector (5m)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "postgres", "uid": "metricmesh-tsdb" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 1, "stacking": { "mode": "normal", "group": "A" } }, "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "metricmesh-tsdb" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroupAlias(created_at, '5m'), detector, count(*) AS alerts FROM alerts WHERE $__timeFilter(created_at) GROUP BY 1, detector ORDER BY 1"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Metric value — $metric (1m avg / min / max)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "postgres", "uid": "metricmesh-tsdb" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "metricmesh-tsdb" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroupAlias(\"time\", '1m'), avg(value) AS \"avg\", max(value) AS \"max\", min(value) AS \"min\" FROM metrics WHERE $__timeFilter(\"time\") AND metric_name = '$metric' GROUP BY 1 ORDER BY 1"
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Top metrics by alert volume",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "postgres", "uid": "metricmesh-tsdb" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "metricmesh-tsdb" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT metric_name AS \"Metric\", count(*) AS \"Alerts\", round(max(score)::numeric, 3) AS \"Max score\" FROM alerts WHERE $__timeFilter(created_at) GROUP BY metric_name ORDER BY \"Alerts\" DESC"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Celery queue depth (MM-8.6)",
      "description": "Tasks waiting in each Celery queue, from prometheus_client (metricmesh_queue_depth).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "metricmesh-prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "showPoints": "never" }, "color": { "mode": "palette-classic" }, "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "metricmesh-prometheus" },
          "expr": "metricmesh_queue_depth",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Detection latency p95 by detector (MM-8.6)",
      "description": "95th-percentile detector fit+detect duration (metricmesh_detection_duration_seconds).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "metricmesh-prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "color": { "mode": "palette-classic" }, "unit": "s" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "metricmesh-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(metricmesh_detection_duration_seconds_bucket[5m])) by (le, detector))",
          "legendFormat": "{{detector}}"
        }
      ]
    }
  ]
}
