# Database
DATABASE_URL=postgresql+asyncpg://mm:mm@localhost:5432/metricmesh
DATABASE_URL_SYNC=postgresql+psycopg2://mm:mm@localhost:5432/metricmesh
# Drop raw metric chunks older than this many days (0 = keep forever)
METRICS_RETENTION_DAYS=30

# Prometheus scraper (opt-in service). Set a target /metrics URL to enable.
PROMETHEUS_SCRAPE_URL=
PROMETHEUS_SCRAPE_INTERVAL=15
PROMETHEUS_SCRAPE_BATCH_SIZE=200

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Alerting
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
PAGERDUTY_ROUTING_KEY=
# Additional sinks (MM-6.5) — opt-in; empty = sink not registered.
TEAMS_WEBHOOK_URL=
GENERIC_WEBHOOK_URL=
# Optional headers for the generic webhook, as a JSON object.
# GENERIC_WEBHOOK_HEADERS={"Authorization":"Bearer xxx"}
# Email sink registers only when SMTP_HOST and ALERT_EMAIL_TO are both set.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
# SMS text sink (Twilio) registers only when all four of TWILIO_ACCOUNT_SID,
# TWILIO_AUTH_TOKEN, SMS_FROM and SMS_TO are set. Numbers are E.164 (+1...).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SMS_FROM=
SMS_TO=
# Optional per-metric routing rules (JSON, first match wins). Empty = all sinks.
# Sink names: log, slack, pagerduty, teams, webhook, email, sms.
# ALERT_ROUTING_RULES=[{"match":"db.*","sinks":["pagerduty","log"]},{"match":"*","sinks":["log"]}]

# Secret store: when /run/secrets (or $SECRETS_DIR) is mounted, any setting can
# be supplied as a file named after the field (e.g. /run/secrets/slack_webhook_url).
# SECRETS_DIR=/run/secrets

# Detection thresholds
ZSCORE_THRESHOLD=0.8
IQR_THRESHOLD=0.8
PROPHET_THRESHOLD=0.5
ISOLATION_FOREST_THRESHOLD=0.75
# Per-metric threshold overrides (MM-10.2): JSON {metric-glob: {detector: threshold}}.
# First matching glob wins; missing detectors fall back to the globals above.
# METRIC_THRESHOLDS={"db.*": {"zscore": 0.9, "isolation_forest": 0.85}, "cpu.usage": {"prophet": 0.6}}
# Score normalisation (MM-3.6): "relative" (per-batch, default) or "absolute"
# (fixed reference → thresholds stable across windows). iqr/prophet always absolute.
SCORING_MODE=relative
# Detector model reuse (MM-10.1): reuse a persisted statistical model newer than
# this many seconds instead of re-fitting. 0 = always re-fit (default).
# Prophet/Isolation Forest always re-fit (metadata-only persistence).
MODEL_REUSE_MAX_AGE_SECONDS=0
ALERT_COOLDOWN_SECONDS=300
# Dedup/consensus time-bucket width in seconds (MM-5.3). Anomalies in the same
# floor(epoch / DEDUP_BUCKET_SECONDS) window are treated as one event for both
# deduplication and consensus grouping. Default 300 (5 min).
DEDUP_BUCKET_SECONDS=300
# Ensemble/consensus (MM-10.5): require this many DISTINCT detectors to agree on
# the same metric/time-bucket before an anomaly is routed. 1 = disabled (default).
CONSENSUS_MIN_DETECTORS=1

# Grafana
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=

# API security
# Comma-separated CORS allow-list (never use "*").
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8000
# Comma-separated API keys. Empty = auth disabled (dev). Set to require X-API-Key.
API_KEYS=
# Multi-tenancy (MM-9.3): JSON map of API key -> tenant. Keys in API_KEYS above
# map to DEFAULT_TENANT. Ingested metrics are tagged with the caller's tenant and
# reads are filtered by it, so tenants never see each other's data. Empty + no
# API_KEYS = single-tenant dev mode. e.g. {"acme-key":"acme","globex-key":"globex"}
TENANT_API_KEYS=
DEFAULT_TENANT=default
# Max ingest requests/min per client (API key, else IP). 0 = disabled.
RATE_LIMIT_PER_MINUTE=0
# Audit trail (MM-9.5): record who/what/when for auth denials, feedback, and
# alert routing into audit_log (inspect via GET /api/v1/audit). Best-effort;
# the raw API key is never stored (only a hashed id). Set false to disable.
AUDIT_ENABLED=true

# App
LOG_LEVEL=INFO
